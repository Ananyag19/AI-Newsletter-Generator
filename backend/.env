# Default LLM provider used on first run: "groq", "gemini", "qwen", or "grok_drive"
# NOTE: after the server has started once, the ADMIN PANEL's choice (persisted
# in backend/data/runtime_state.json) takes over — this value is just the
# initial default. Regular users never see this setting; only the admin panel
# (gated by ADMIN_TOKEN below) can change it.
AI_PROVIDER=groq

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Qwen via Alibaba Cloud DashScope (https://dashscope.console.aliyun.com/apiKey)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions

# --- Grok via Google Drive (no xAI API key needed) ---
# Auth is OAuth as YOUR OWN Google account — NOT a service account (service
# accounts have zero Drive storage quota and can't create files, even in a
# folder shared with them; you'll get a 403 storageQuotaExceeded error).
#
# 1. In Google Cloud Console: enable the Drive API, then create an OAuth
#    client ID (Credentials > Create Credentials > OAuth client ID > type
#    "Desktop app"). Download the JSON and put its path below.
# 2. Run `python scripts/get_drive_token.py` once from backend/ — it opens a
#    browser for a one-time sign-in as the SAME Google account connected to
#    Grok's Drive connector, then saves a token file. You won't need to
#    repeat this unless you revoke access.
# 3. Pick (or create) a folder that already exists in that account's own
#    Drive — no sharing step needed, you own it outright. Copy its ID from
#    the folder's URL into GOOGLE_DRIVE_FOLDER_ID.
GOOGLE_OAUTH_CLIENT_SECRETS_FILE=./credentials/oauth_client.json
GOOGLE_OAUTH_TOKEN_FILE=./credentials/drive_token.json
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here
GROK_DRIVE_POLL_INTERVAL_SECONDS=15
GROK_DRIVE_MAX_WAIT_SECONDS=1800

# --- Admin panel ---
# Required to view/change the active AI provider via the frontend's admin
# panel (or directly via GET/POST /admin/provider). Pick any long random
# string; leave blank to disable the admin panel entirely (returns 500).
ADMIN_TOKEN=change_me_to_a_long_random_string

# Server
HOST=0.0.0.0
PORT=8000

# CORS - comma separated list of allowed origins, or * for all
ALLOWED_ORIGINS=*

# Chunking
CHUNK_MAX_WORDS=900
CHUNK_OVERLAP_WORDS=80

# Request timeouts (seconds)
URL_FETCH_TIMEOUT=15
LLM_REQUEST_TIMEOUT=60
